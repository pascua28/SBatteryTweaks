<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- ==================== TOOLBAR ==================== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:minHeight="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="@string/app_name"
            app:titleTextAppearance="@style/ToolBarTitle"
            app:titleTextColor="@color/oui_des_primary_text_color">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/settingsBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:background="@drawable/ic_oui_settings"
                android:clickable="true"
                android:contentDescription="@string/settings" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/supportBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="8dp"
                android:background="@drawable/donate"
                android:clickable="true"
                android:contentDescription="@string/donate" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ==================== SCROLL VIEW ==================== -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- ==================== TOP ROW (Battery + Temp) ==================== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp">

                <!-- LEFT CARD – Battery Level -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:id="@+id/batteryCard"
                    style="@style/TopCardView"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Fill background wave -->
                        <com.scwang.wave.MultiWaveHeader
                            android:id="@+id/waveHeader"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:scaleY="-1"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:mwhCloseColor="#FF90CAF9"
                            app:mwhColorAlpha="0.3"
                            app:mwhGradientAngle="180"
                            app:mwhIsRunning="true"
                            app:mwhProgress="0"
                            app:mwhStartColor="#FF42A5F5"
                            app:mwhVelocity="0.4"
                            app:mwhWaveHeight="15dp"
                            app:mwhWaves="PairWave" />

                        <!-- Title centered horizontally at the top -->
                        <TextView
                            android:id="@+id/batteryTitle"
                            style="@style/TopCardText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/battery_level"
                            android:textColor="@color/oui_des_primary_text_color"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Battery percentage centered both horizontally & vertically -->
                        <TextView
                            android:id="@+id/levelText"
                            style="@style/BatteryViewDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="@color/oui_des_primary_text_color"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <!-- RIGHT CARD – Temperature -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:id="@+id/tempCard"
                    style="@style/TopCardView"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/batteryCard">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Title centered horizontally at top -->
                        <TextView
                            android:id="@+id/tempTitle"
                            style="@style/TopCardText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/temperature"
                            android:textColor="@color/oui_des_primary_text_color"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Centered temperature text -->
                        <TextView
                            android:id="@+id/tempText"
                            style="@style/BatteryViewDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <!-- Gap between the two cards -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline_center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_begin="206dp" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tempCard"
                    app:layout_constraintStart_toEndOf="@id/batteryCard"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ==================== BOTTOM INFO CARDS ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <!-- Status -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:id="@+id/cardView"
                    style="@style/CardViewDisplay"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            style="@style/StatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/status" />

                        <TextView
                            android:id="@+id/chargingText"
                            style="@style/ValueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <!-- Fast charging -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    style="@style/CardViewDisplay"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            style="@style/StatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/fast_charging" />

                        <TextView
                            android:id="@+id/fastCharge"
                            style="@style/ValueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <!-- Current -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    style="@style/CardViewDisplay"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            style="@style/StatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/current" />

                        <TextView
                            android:id="@+id/currentText"
                            style="@style/ValueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <!-- Rated capacity -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    style="@style/CardViewDisplay"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            style="@style/StatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/rated_capacity" />

                        <TextView
                            android:id="@+id/capacityText"
                            style="@style/ValueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <!-- Remaining capacity -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:id="@+id/capacityView"
                    style="@style/CardViewDisplay"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            style="@style/StatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/remaining_capacity" />

                        <TextView
                            android:id="@+id/remainingCap"
                            style="@style/ValueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <!-- Voltage level -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    style="@style/CardViewDisplay"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            style="@style/StatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/voltage_level" />

                        <TextView
                            android:id="@+id/voltageText"
                            style="@style/ValueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <!-- Idle charging toggle -->
                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:id="@+id/idleCardView"
                    style="@style/CardViewDisplay"
                    android:layout_marginBottom="96dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/bypassText"
                            style="@style/StatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/bypassToggle"
                            style="@style/BatteryViewDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="15dp" />
                    </LinearLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>