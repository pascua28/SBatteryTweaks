<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BatteryViewDisplay">
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center_vertical|center_horizontal</item>
        <item name="android:maxLines">1</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="TopCardView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">120dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@color/oui_des_background_color</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="elevation">10dp</item>
        <item name="layout_constraintWidth_percent">0.45</item>
        <item name="android:layout_marginLeft">10dp</item>
        <item name="android:layout_marginRight">10dp</item>
    </style>

    <style name="CardViewDisplay">
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_marginLeft">10dp</item>
        <item name="android:layout_marginRight">10dp</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:background">@color/oui_des_background_color</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardElevation">10dp</item>
        <item name="cardMaxElevation">12dp</item>
        <item name="cornerRadius">4dp</item>
        <item name="layout_anchorGravity">bottom|center</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.MaterialCardView.Cut</item>
    </style>

    <style name="ShapeAppearanceOverlay.MaterialCardView.Cut" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeTopLeft">12dp</item>
        <item name="cornerSizeBottomRight">12dp</item>
        <item name="cornerSizeBottomLeft">12dp</item>
    </style>

    <style name="TopCardText">
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center_vertical|center_horizontal</item>
        <item name="android:maxLines">1</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:layout_gravity">top|center</item>
        <item name="android:layout_marginTop">10dp</item>
    </style>

    <style name="StatusText">
        <item name="android:textSize">15sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">left|center_vertical</item>
        <item name="android:layout_marginLeft">15dp</item>
    </style>

    <style name="ValueText">
        <item name="android:textSize">15sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">right|center_vertical</item>
        <item name="android:layout_marginRight">15dp</item>
    </style>

    <style name="ToolBarTitle">
        <item name="android:textSize">20sp</item>
    </style>
</resources>